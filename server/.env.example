# Gamer Beta 环境变量配置
# 复制此文件为 .env 并填入实际值

# 服务器端口
PORT=3000

# JWT 签名密钥（生产环境请务必更换为随机字符串）
JWT_SECRET=gamer_beta_secret_key_change_me

# SQLite 数据库文件路径
DB_PATH=./data/gamer_beta.db

# 文件上传目录
UPLOAD_DIR=./uploads

# LLM API 配置（支持 OpenAI 兼容接口：DeepSeek / OpenAI / 各类代理）
# 必填：你的 API Key
OPENAI_API_KEY=sk-your-api-key-here

# API 地址（可选，默认为 DeepSeek）
# DeepSeek: https://api.deepseek.com/v1
# OpenAI:  https://api.openai.com/v1
# 代理示例: https://your-proxy.com/v1
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 模型名称（可选）
# deepseek-chat / gpt-4o / gpt-3.5-turbo 等
OPENAI_MODEL=deepseek-chat
