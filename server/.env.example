# Gamer Beta 环境变量配置
# 复制此文件为 .env 并填入实际值

# 服务器端口
PORT=3000

# JWT 签名密钥（生产环境请务必更换为随机字符串）
JWT_SECRET=gamer_beta_secret_key_change_me

# SQLite 数据库文件路径
DB_PATH=./data/gamer_beta.db

# 文件上传目录
UPLOAD_DIR=./uploads

# LLM API 配置（支持 OpenAI 兼容接口：GPT-4o / DeepSeek / 各类代理）
# 必填：你的 API Key
OPENAI_API_KEY=sk-your-api-key-here

# API 地址（可选）
# OpenAI GPT-4o:  https://api.openai.com/v1    ← 支持 Vision 多模态
# DeepSeek:       https://api.deepseek.com/v1  ← 纯文本模型
# 代理示例:       https://your-proxy.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名称（可选）
# gpt-4o (推荐，支持 Vision) / gpt-3.5-turbo / deepseek-chat 等
OPENAI_MODEL=gpt-4o

# GitHub OAuth 配置（可选，用于 GitHub 登录 + 推送游戏到仓库）
# 在 https://github.com/settings/developers 创建 OAuth App
# Homepage URL: http://localhost:5173
# Callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# 前端地址（OAuth 回调跳转用）
FRONTEND_URL=http://localhost:5173
